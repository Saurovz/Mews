        "ServiceBus": {
            "Connections": {
                "Scheduler": {
                    "Publishing": {
                        "TopicName": "job-scheduler-notifications"
                    },
                    "PublishResilienceSettings": {
                        "CircuitBreakerFailureThreshold": 2,
                        "CircuitBreakerOpenWindow": "00:00:30"
                    },
                    "PublishClientSettings": {
                        "MaxRetries": 2,
                        "MaxDelay": "00:00:05",
                        "TryTimeout": "00:00:05"
                    }
                }
            }
        }
    },
    "HostedServiceConfigurations": {
