{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
    },
    "AzureAd": {
        "Instance": "https://login.microsoftonline.com/",
        "TenantId": "afdb37c2-13f1-4a78-b91e-85749ac8e807",
        "ClientId": "<overridden by env var>",
        "Audience": "api://job-scheduler-s2s-prod",
        "AllowWebApiToBeAuthorizedByACL": true
    },
    "SqlConfiguration": {
        "RetryExecutionStrategy": {
            "MaxRetryCount": 3,
            "MaxRetryDelay": "00:00:20"
        }
    },
