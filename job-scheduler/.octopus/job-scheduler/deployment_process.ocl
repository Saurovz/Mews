step "register-linearb-deployment" {
    name = "Register LinearB Deployment"

    action {
        action_type = "Octopus.Script"
        properties = {
            Octopus.Action.GitRepository.Source = "External"
            Octopus.Action.Script.ScriptFileName = "octopus/linearb-register-deployment.sh"
            Octopus.Action.Script.ScriptParameters = "\"https://github.com/MewsSystems/job-scheduler.git\" \"#{Octopus.Release.Git.CommitHash}\" \"#{Octopus.Environment.Name}\""
            Octopus.Action.Script.ScriptSource = "GitRepository"
        }
        worker_pool = "azure-workers"

        git_dependencies {
            default_branch = "main"
            git_credential_id = "GitCredentials-22"
            git_credential_type = "Library"
            repository_uri = "https://github.com/MewsSystems/deployment-scripts.git"
        }
    }
}